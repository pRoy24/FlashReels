FLASHREELS_SECRET=
FLASHREELS_AUTH_SECRET=
FLASHREELS_SERVER_SECRET=
FLASHREELS_PUBLIC_BASE_URL=
FLASHREELS_ENV_FILE=.env.local
FLASHREELS_WRITE_ENV_FILE=

FLASHREELS_SAMSAR_API_KEY=
FLASHREELS_RUNWAYML_API_KEY=

# Optional fallbacks.
SAMSAR_API_KEY=
RUNWAYML_API_SECRET=
RUNWAY_API_KEY=
SAMSAR_API_BASE_URL=https://api.samsar.one
RUNWAY_API_BASE_URL=https://api.dev.runwayml.com
RUNWAY_API_VERSION=2024-11-06
RUNWAY_IMAGE_MODEL=gen4_image
RUNWAY_VIDEO_MODEL=gen4.5

# Vercel Marketplace Redis / Upstash Redis REST variables.
# The default Vercel Redis connector injects these automatically.
KV_REST_API_URL=
KV_REST_API_TOKEN=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
